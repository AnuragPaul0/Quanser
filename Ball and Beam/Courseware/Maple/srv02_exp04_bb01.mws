!\"\"F1F1*&&F.6#%\"vGF1-%%diffG6$F8F*F1F<" }}}{EXCHG {PARA 0 "" 0 "" 
{TEXT -1 31 "Transfer function of PV control" }}{PARA 0 "> " 0 "" 
{MPLTEXT 1 0 98 "ctrl_pv_tf := V[m](s) = k[p] * ( Theta[d](s) - Theta[
l](s) ) - k[v] * s * Theta[l](s):\nctrl_pv_tf;" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#/-&%\"VG6#%\"mG6#%\"sG,&*&&%\"kG6#%\"pG\"\"\",&-&%&Thet
aG6#%\"dGF)F1-&F56#%\"lGF)!\"\"F1F1*(&F.6#%\"vGF1F*F1F8F1F<" }}}{PARA 
0 "" 0 "" {TEXT -1 56 "Closed-loop SRV02 PV position control transfer \+
function." }}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 130 "tf_cls_pos := \+
Theta[l](s) / Theta[d](s) = collect( solve( subs(ctrl_pv_tf,tf_pos_vm)
, Theta[l](s) ) / Theta[d](s), s):\ntf_cls_pos;" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#/*&-&%&ThetaG6#%\"lG6#%\"sG\"\"\"-&F'6#%\"dGF*!\"\"*(%
